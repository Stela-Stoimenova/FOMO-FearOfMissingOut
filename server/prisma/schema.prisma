generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DANCER
  STUDIO
  AGENCY
}

enum CollaborationStatus {
  PENDING
  ACTIVE
  ENDED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ClassLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
  ALL_LEVELS
}

enum TeamRole {
  DANCER
  INSTRUCTOR
  CHOREOGRAPHER
}

enum CvEntryType {
  TRAINING
  PROJECT
  WORKSHOP
  COMPETITION
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  email     String   @unique
  password  String
  name      String?
  avatarUrl String?
  role      Role

  // Dancer profile fields
  bio             String?
  city            String?
  danceStyles     String[]  @default([])
  experienceLevel String?
  portfolioLinks  String[]  @default([])
  portfolioItems  PortfolioItem[]
  taggedEvents    Event[]   @relation("TaggedEvents")
  payoutDetails   String?

  // Core
  events  Event[]  @relation("EventCreator")
  tickets Ticket[]

  // Loyalty
  loyaltyAccount      LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]

  // Social
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")

  // Messaging
  sentMessages     Message[] @relation("UserSentMessages")
  receivedMessages Message[] @relation("UserReceivedMessages")

  // Weekly Classes
  studioClasses   WeeklyClass[] @relation("StudioClasses")
  teacherClasses  WeeklyClass[] @relation("TeacherClasses")

  // Memberships
  membershipTiers      MembershipTier[] @relation("StudioMemberships")
  purchasedMemberships UserMembership[] @relation("DancerMemberships")

  // Team
  studioTeamMembers StudioTeamMember[] @relation("StudioTeam")
  teamsJoined       StudioTeamMember[] @relation("UserTeams")

  // Collaborations
  studioCollaborations Collaboration[] @relation("StudioCollaborations")
  agencyCollaborations Collaboration[] @relation("AgencyCollaborations")

  // CV
  cvEntries          CvEntry[] @relation("DancerCv")
  taggedInCvAsStudio CvEntry[] @relation("TaggedInCvAsStudio")
  taggedInCvAsAgency CvEntry[] @relation("TaggedInCvAsAgency")

  // Agency roster
  managedDancers AgencyRoster[] @relation("AgencyRoster")
  representedBy  AgencyRoster[] @relation("DancerInRoster")
}

model Event {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  title       String
  description String?
  location    String
  startAt     DateTime
  endAt       DateTime?
  priceCents  Int
  capacity    Int?
  latitude    Float?
  longitude   Float?
  imageUrl String?

  creatorId Int
  creator   User @relation("EventCreator", fields: [creatorId], references: [id])

  tickets Ticket[]
  taggedUsers User[] @relation("TaggedEvents")
}

model PortfolioItem {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // "PHOTO" | "VIDEO"
  url         String
  title       String?
  description String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId     Int
  eventId    Int
  priceCents Int

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  transaction Transaction?

  @@unique([userId, eventId])
  @@index([eventId])
}

model LoyaltyAccount {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  points    Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model LoyaltyTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  points    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Transaction {
  id              Int      @id @default(autoincrement())
  ticketId        Int      @unique
  grossCents      Int
  commissionCents Int
  netCents        Int
  createdAt       DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
}

model Follow {
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id])
  following User @relation("UserFollowers", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model Message {
  id         Int       @id @default(autoincrement())
  senderId   Int
  receiverId Int
  content    String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  sender   User @relation("UserSentMessages", fields: [senderId], references: [id])
  receiver User @relation("UserReceivedMessages", fields: [receiverId], references: [id])
}

model WeeklyClass {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  studioId    Int
  title       String
  dayOfWeek   DayOfWeek
  startTime   String     // e.g., "18:00"
  endTime     String     // e.g., "19:30"
  style       String
  level       ClassLevel
  teacherName String?    // Used if the teacher is not registered on the platform
  teacherId   Int?       // Used if the teacher is a registered User
  capacity    Int?       // Null means unlimited

  studio      User       @relation("StudioClasses", fields: [studioId], references: [id], onDelete: Cascade)
  teacher     User?      @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([studioId])
  @@index([teacherId])
}

model MembershipTier {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  studioId     Int
  name         String   
  description  String?
  priceCents   Int
  classLimit   Int?     // Null means unlimited classes
  durationDays Int      // e.g., 30 for monthly
  isActive     Boolean  @default(true)
  
  studio       User     @relation("StudioMemberships", fields: [studioId], references: [id], onDelete: Cascade)
  purchases    UserMembership[]

  @@index([studioId])
}

model UserMembership {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  dancerId        Int
  tierId          Int
  purchasedAt     DateTime @default(now())
  expiresAt       DateTime
  creditsTotal    Int?     // Copied from tier at time of purchase
  creditsUsed     Int      @default(0)
  active          Boolean  @default(true)
  
  dancer          User           @relation("DancerMemberships", fields: [dancerId], references: [id], onDelete: Cascade)
  tier            MembershipTier @relation(fields: [tierId], references: [id], onDelete: Restrict)

  @@index([dancerId])
  @@index([tierId])
}

model StudioTeamMember {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  studioId  Int
  userId    Int
  role      TeamRole
  joinedAt  DateTime @default(now())

  studio    User     @relation("StudioTeam", fields: [studioId], references: [id], onDelete: Cascade)
  user      User     @relation("UserTeams", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studioId, userId, role])
  @@index([studioId])
  @@index([userId])
}

model Collaboration {
  studioId    Int
  agencyId    Int
  description String?
  status      CollaborationStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio      User @relation("StudioCollaborations", fields: [studioId], references: [id], onDelete: Cascade)
  agency      User @relation("AgencyCollaborations", fields: [agencyId], references: [id], onDelete: Cascade)

  @@id([studioId, agencyId])
  @@index([studioId])
  @@index([agencyId])
}

model CvEntry {
  id              Int         @id @default(autoincrement())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userId          Int
  type            CvEntryType
  title           String
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  choreographer   String?     // Manual entry if choreographer is not on platform
  
  // Optional linking to existing entities
  taggedStudioId  Int?
  taggedAgencyId  Int?

  user            User  @relation("DancerCv", fields: [userId], references: [id], onDelete: Cascade)
  taggedStudio    User? @relation("TaggedInCvAsStudio", fields: [taggedStudioId], references: [id], onDelete: SetNull)
  taggedAgency    User? @relation("TaggedInCvAsAgency", fields: [taggedAgencyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taggedStudioId])
  @@index([taggedAgencyId])
}

model AgencyRoster {
  id        Int      @id @default(autoincrement())
  agencyId  Int
  dancerId  Int
  notes     String?
  createdAt DateTime @default(now())

  agency    User     @relation("AgencyRoster", fields: [agencyId], references: [id], onDelete: Cascade)
  dancer    User     @relation("DancerInRoster", fields: [dancerId], references: [id], onDelete: Cascade)

  @@unique([agencyId, dancerId])
  @@index([agencyId])
  @@index([dancerId])
}
