{
    "info": {
        "name": "FOMO API",
        "_postman_id": "fomo-api-collection-v1",
        "description": "Demo collection for FOMO – Fear Of Missing Out dance platform API.\n\nSet `baseUrl` and `token` variables before running.\n\nFlow: Register Studio → Login Studio → Create Event → Register Dancer → Login Dancer → Buy Ticket → Try Duplicate → Popular → Nearby",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000/api",
            "type": "string"
        },
        {
            "key": "studioToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "dancerToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "eventId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register Studio",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.token) pm.collectionVariables.set('studioToken', json.token);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"studio@fomo.dev\",\n  \"password\": \"studio123\",\n  \"name\": \"Pulse Dance Studio\",\n  \"role\": \"STUDIO\"\n}"
                        }
                    }
                },
                {
                    "name": "Login Studio",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.token) pm.collectionVariables.set('studioToken', json.token);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"studio@fomo.dev\",\n  \"password\": \"studio123\"\n}"
                        }
                    }
                },
                {
                    "name": "Register Dancer",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.token) pm.collectionVariables.set('dancerToken', json.token);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"dancer@fomo.dev\",\n  \"password\": \"dancer123\",\n  \"name\": \"Alex Ivanov\",\n  \"role\": \"DANCER\"\n}"
                        }
                    }
                },
                {
                    "name": "Login Dancer",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.token) pm.collectionVariables.set('dancerToken', json.token);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"dancer@fomo.dev\",\n  \"password\": \"dancer123\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Events",
            "item": [
                {
                    "name": "Create Event (Studio)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.id) pm.collectionVariables.set('eventId', String(json.id));"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{studioToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/events",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Postman Test Event\",\n  \"description\": \"Created via Postman\",\n  \"location\": \"Sofia, Bulgaria\",\n  \"startAt\": \"2026-08-01T18:00:00Z\",\n  \"priceCents\": 2000,\n  \"capacity\": 5,\n  \"latitude\": 42.6977,\n  \"longitude\": 23.3219\n}"
                        }
                    }
                },
                {
                    "name": "List Events",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/events?page=1&limit=10",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Event by ID",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/events/{{eventId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events",
                                "{{eventId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Popular Events",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/events/popular",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events",
                                "popular"
                            ]
                        }
                    }
                },
                {
                    "name": "Nearby Events (Sofia)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/events/nearby?lat=42.6977&lng=23.3219&radius=5",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events",
                                "nearby"
                            ],
                            "query": [
                                {
                                    "key": "lat",
                                    "value": "42.6977"
                                },
                                {
                                    "key": "lng",
                                    "value": "23.3219"
                                },
                                {
                                    "key": "radius",
                                    "value": "5"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Tickets",
            "item": [
                {
                    "name": "Buy Ticket (Dancer)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{dancerToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/events/{{eventId}}/tickets",
                            "host": [
