                                "key": "Authorization",
                                "value": "Bearer {{dancerToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/events/{{eventId}}/tickets",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "events",
                                "{{eventId}}",
                                "tickets"
                            ]
                        }
                    }
                },
